---
import { workTimeline } from '@/data/select';
import TimelineList from './TimelineList.astro';
const { engagements, side } = workTimeline();
const engagementProjectCount = engagements.reduce((sum, g) => sum + g.children.length, 0);
const sideProjectCount = side.reduce((sum, g) => sum + g.children.length, 0);
---
<section class="section" id="more">
  <div class="sec-num">// 04</div>
  <h2 class="sec-title">All <em>work</em></h2>
  <p class="sec-eyebrow">
    {engagementProjectCount} client / program projects across {engagements.length} engagements
    {sideProjectCount > 0 && <> · {sideProjectCount} side projects</>}. ★ = featured above.
  </p>

  <!-- ============ Section A: paid work at Deloitte ============ -->
  <div class="sub-section">
    <div class="sub-section-label">// engagements</div>
    <h3 class="sub-section-title">Work at <em>Deloitte</em></h3>
    <p class="sub-section-eyebrow">Client engagements and internal programs. Current → past.</p>
    <TimelineList groups={engagements} />
  </div>

  <!-- ============ Section B: side / hackathon projects ============ -->
  {side.length > 0 && (
    <div class="sub-section">
      <div class="sub-section-label">// side</div>
      <h3 class="sub-section-title">Projects &amp; <em>hackathons</em></h3>
      <p class="sub-section-eyebrow">Things I built on my own time and in weekend sprints. Current → past.</p>
      <TimelineList groups={side} />
    </div>
  )}
</section>

<style>
  .section { padding: 70px 40px; }
  .sec-num { font: 700 10px/1 var(--font-mono); letter-spacing: 0.22em; color: var(--accent-orange); }
  .sec-title { font: 700 36px/1 var(--font-display); letter-spacing: -0.03em; color: #fff; margin: 12px 0 0; }
  .sec-title em { color: var(--accent-warm); font-style: normal; font-family: var(--font-italic); font-weight: 400; }
  .sec-eyebrow { font: 400 13px/1.4 var(--font-display); color: var(--text-muted); margin: 10px 0 0; }

  .sub-section {
    margin-top: 48px;
  }
  .sub-section:first-of-type { margin-top: 40px; }
  .sub-section-label {
    font: 700 9px/1 var(--font-mono);
    letter-spacing: 0.22em;
    color: var(--accent-orange);
    margin-bottom: 6px;
  }
  .sub-section-title {
    font: 700 22px/1.15 var(--font-display);
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0 0 4px;
  }
  .sub-section-title em {
    color: var(--accent-warm);
    font-style: normal;
    font-family: var(--font-italic);
    font-weight: 400;
  }
  .sub-section-eyebrow {
    font: 400 12px/1.4 var(--font-display);
    color: var(--text-muted);
    margin: 0;
  }
</style>
