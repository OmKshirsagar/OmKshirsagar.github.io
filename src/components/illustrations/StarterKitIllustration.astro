---
// Featured 02 — FastAPI Starter Kit illustration
// A 3-layer architectural stack drawn as one big square puzzle:
//   TOP    — OBSERVABILITY (wide strip covering all 3 modules)
//   MIDDLE — MCP · AUTH · DB  (3 cells side-by-side)
//   BOTTOM — FastAPI BASE FRAMEWORK (wide strip foundation)
// Services built on top (VOICE AI / AGENT / DATA API) hover above.
//
// All puzzle tabs/slots are generated by piecePath() so the sweep-flag
// gymnastics from the previous hand-drawn version can't bite again:
// type 'tab' always bulges outward, 'slot' always bulges inward.

interface Feature {
  at: number;
  type: 'tab' | 'slot';
}

interface PieceConfig {
  x: number;
  y: number;
  w: number;
  h: number;
  top?: Feature[];
  right?: Feature[];
  bottom?: Feature[];
  left?: Feature[];
}

const R = 8; // tab/slot radius

// piecePath returns an SVG `d` string for one puzzle piece. Each edge can
// have any number of tab/slot features in left→right / top→bottom order;
// the path traverses clockwise (top L→R, right T→B, bottom R→L, left B→T)
// so features on the bottom and left edges are emitted in reverse order
// by the helper — callers always pass them in natural reading order.
function piecePath(p: PieceConfig): string {
  const r = R;
  const sweep = (t: Feature['type']): 0 | 1 => (t === 'tab' ? 1 : 0);
  let d = `M ${p.x} ${p.y}`;

  for (const f of p.top ?? []) {
    d += ` L ${f.at - r} ${p.y} A ${r} ${r} 0 0 ${sweep(f.type)} ${f.at + r} ${p.y}`;
  }
  d += ` L ${p.x + p.w} ${p.y}`;

  for (const f of p.right ?? []) {
    d += ` L ${p.x + p.w} ${f.at - r} A ${r} ${r} 0 0 ${sweep(f.type)} ${p.x + p.w} ${f.at + r}`;
  }
  d += ` L ${p.x + p.w} ${p.y + p.h}`;

  for (const f of [...(p.bottom ?? [])].reverse()) {
    d += ` L ${f.at + r} ${p.y + p.h} A ${r} ${r} 0 0 ${sweep(f.type)} ${f.at - r} ${p.y + p.h}`;
  }
  d += ` L ${p.x} ${p.y + p.h}`;

  for (const f of [...(p.left ?? [])].reverse()) {
    d += ` L ${p.x} ${f.at + r} A ${r} ${r} 0 0 ${sweep(f.type)} ${p.x} ${f.at - r}`;
  }
  d += ` L ${p.x} ${p.y} Z`;
  return d;
}

// === Puzzle layout (180×180 square centered horizontally) ===
// Three rows of 60px each, spanning x=60→240, y=60→240.
const fastapiPath = piecePath({
  x: 60, y: 180, w: 180, h: 60,
  top: [
    { at: 90, type: 'slot' },
    { at: 150, type: 'slot' },
    { at: 210, type: 'slot' },
  ],
});

const mcpPath = piecePath({
  x: 60, y: 120, w: 60, h: 60,
  top: [{ at: 90, type: 'slot' }],
  right: [{ at: 150, type: 'tab' }],
  bottom: [{ at: 90, type: 'tab' }],
});

const authPath = piecePath({
  x: 120, y: 120, w: 60, h: 60,
  top: [{ at: 150, type: 'slot' }],
  right: [{ at: 150, type: 'tab' }],
  bottom: [{ at: 150, type: 'tab' }],
  left: [{ at: 150, type: 'slot' }],
});

const dbPath = piecePath({
  x: 180, y: 120, w: 60, h: 60,
  top: [{ at: 210, type: 'slot' }],
  bottom: [{ at: 210, type: 'tab' }],
  left: [{ at: 150, type: 'slot' }],
});

const obsPath = piecePath({
  x: 60, y: 60, w: 180, h: 60,
  bottom: [
    { at: 90, type: 'tab' },
    { at: 150, type: 'tab' },
    { at: 210, type: 'tab' },
  ],
});
---
<div class="illu">
  <svg viewBox="0 0 300 300" fill="none">
    <defs>
      <linearGradient id="kit-core" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#ffe6b8"/>
        <stop offset="100%" stop-color="#ff9460"/>
      </linearGradient>
      <radialGradient id="kit-halo" cx="50%" cy="55%" r="55%">
        <stop offset="0%" stop-color="#ffaa78" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="#ffaa78" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- ambient halo -->
    <ellipse cx="150" cy="160" rx="130" ry="110" fill="url(#kit-halo)"/>

    <!-- ============================================================== -->
    <!--  SERVICES BUILT ON TOP — 3 small cards hovering above puzzle   -->
    <!-- ============================================================== -->
    <g>
      <g transform="translate(20, 22)">
        <rect width="72" height="34" rx="3" fill="#14141c" stroke="#ffaa78" stroke-width="1.2"/>
        <rect x="6" y="6" width="6" height="6" fill="#ffaa78"/>
        <rect x="14" y="6" width="6" height="6" fill="#ffaa78" opacity="0.55"/>
        <rect x="22" y="6" width="6" height="6" fill="#ffaa78" opacity="0.3"/>
        <text font-family="JetBrains Mono" font-size="10" font-weight="700" letter-spacing="1.5" fill="#ffaa78" x="36" y="25" text-anchor="middle">VOICE AI</text>
      </g>

      <g transform="translate(114, 18)">
        <rect width="72" height="34" rx="3" fill="#14141c" stroke="#8a6da0" stroke-width="1.2"/>
        <rect x="6" y="6" width="6" height="6" fill="#8a6da0"/>
        <rect x="14" y="6" width="6" height="6" fill="#8a6da0" opacity="0.55"/>
        <rect x="22" y="6" width="6" height="6" fill="#8a6da0" opacity="0.3"/>
        <text font-family="JetBrains Mono" font-size="10" font-weight="700" letter-spacing="1.5" fill="#8a6da0" x="36" y="25" text-anchor="middle">AGENT</text>
      </g>

      <g transform="translate(208, 22)">
        <rect width="72" height="34" rx="3" fill="#14141c" stroke="#5af3d0" stroke-width="1.2"/>
        <rect x="6" y="6" width="6" height="6" fill="#5af3d0"/>
        <rect x="14" y="6" width="6" height="6" fill="#5af3d0" opacity="0.55"/>
        <rect x="22" y="6" width="6" height="6" fill="#5af3d0" opacity="0.3"/>
        <text font-family="JetBrains Mono" font-size="10" font-weight="700" letter-spacing="1.5" fill="#5af3d0" x="36" y="25" text-anchor="middle">DATA API</text>
      </g>
    </g>

    <!-- thin dashed connectors from each service down to the OBS layer -->
    <g stroke="#ffd29a" stroke-width="1" stroke-dasharray="3 2" fill="none" opacity="0.42">
      <path d="M 56 56 L 90 60"/>
      <path d="M 150 52 L 150 60"/>
      <path d="M 244 56 L 210 60"/>
    </g>

    <!-- ============================================================== -->
    <!--  3-LAYER PUZZLE (square)                                       -->
    <!--   FastAPI (base)  →  MCP / AUTH / DB  →  OBSERVABILITY        -->
    <!-- ============================================================== -->

    <!-- BASE: FastAPI -->
    <path d={fastapiPath} fill="url(#kit-core)" stroke="#1a0f08" stroke-width="1.3"/>
    <text x="150" y="208" font-family="Inter" font-size="14" font-weight="800" letter-spacing="-0.4" fill="#1a0f08" text-anchor="middle">FastAPI</text>
    <text x="150" y="224" font-family="JetBrains Mono" font-size="8" font-weight="700" letter-spacing="2.5" fill="#1a0f08" text-anchor="middle">BASE FRAMEWORK</text>

    <!-- MIDDLE row: MCP · AUTH · DB -->
    <path d={mcpPath} fill="#5af3d0" stroke="#1a0f08" stroke-width="1.3"/>
    <text x="90" y="155" font-family="JetBrains Mono" font-size="12" font-weight="800" letter-spacing="2" fill="#1a0f08" text-anchor="middle">MCP</text>

    <path d={authPath} fill="#ffaa78" stroke="#1a0f08" stroke-width="1.3"/>
    <text x="150" y="155" font-family="JetBrains Mono" font-size="12" font-weight="800" letter-spacing="2" fill="#1a0f08" text-anchor="middle">AUTH</text>

    <path d={dbPath} fill="#8a6da0" stroke="#1a0f08" stroke-width="1.3"/>
    <text x="210" y="155" font-family="JetBrains Mono" font-size="12" font-weight="800" letter-spacing="2" fill="#fff5e8" text-anchor="middle">DB</text>

    <!-- TOP: OBSERVABILITY layer -->
    <path d={obsPath} fill="#ffd29a" stroke="#1a0f08" stroke-width="1.3"/>
    <text x="150" y="94" font-family="JetBrains Mono" font-size="11" font-weight="800" letter-spacing="2" fill="#1a0f08" text-anchor="middle">OBSERVABILITY</text>

    <!-- ============================================================== -->
    <!--  Caption                                                       -->
    <!-- ============================================================== -->
    <text x="150" y="265" font-family="JetBrains Mono" font-size="9" font-weight="700" letter-spacing="3" fill="#a09387" text-anchor="middle">
      ONE FOUNDATION · <tspan fill="#ffd29a" font-weight="800">12+</tspan> SERVICES BUILT
    </text>
  </svg>
</div>

<style>
  .illu {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1 / 1;
    background: radial-gradient(ellipse at center, rgba(255, 210, 154, 0.06) 0%, transparent 70%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 1 420px;
    margin: 0 auto;
  }
  .illu svg {
    width: 100%;
    max-width: 400px;
    height: auto;
    display: block;
  }
</style>
