---
interface Props {
  num: string;
  badge: string;
  title: string;
  titleEm?: string;
  meta: string;
  desc: string;
  chips: string[];
  variant: 'left' | 'right';
  slug?: string;
}

const { num, badge, title, titleEm, meta, desc, chips, variant, slug } = Astro.props;

const titleHtml = titleEm
  ? title.split(titleEm).join(`<em>${titleEm}</em>`)
  : title;
---
<div class:list={['feat-band', variant === 'right' && 'reverse']}>
  <div class="illu-col">
    <slot name="illustration" />
  </div>
  <div class="text-col">
    <div class="num">{num}</div>
    <div class="badge">{badge}</div>
    <h3 class="title"><Fragment set:html={titleHtml} /></h3>
    <p class="meta">{meta}</p>
    <p class="desc"><Fragment set:html={desc} /></p>
    <div class="stack">
      {chips.map((c) => <span class="chip">{c}</span>)}
    </div>
    {slug ? (
      <button type="button" class="more" data-case-slug={slug}>
        Read the case study <span aria-hidden="true">→</span>
      </button>
    ) : (
      <a class="more" href="#" aria-disabled="true">Read the case study →</a>
    )}
  </div>
</div>

<script>
  // Dispatch open-case-study event when the Read-more button is clicked.
  // Listener lives in <ProjectModal /> React island.
  document.querySelectorAll<HTMLButtonElement>('button.more[data-case-slug]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const slug = btn.dataset.caseSlug;
      if (!slug) return;
      window.dispatchEvent(new CustomEvent('open-case-study', { detail: { slug } }));
    });
  });
</script>

<style>
  .feat-band {
    margin-top: 50px;
    display: grid;
    grid-template-columns: 420px 1fr;
    gap: 48px;
    align-items: center;
    padding: 36px 0;
    border-top: 1px solid var(--border);
  }
  .feat-band.reverse { grid-template-columns: 1fr 420px; }
  .feat-band.reverse .illu-col { order: 2; }
  .feat-band.reverse .text-col { order: 1; }

  .illu-col { display: flex; justify-content: center; }

  .num { font: 800 56px/1 var(--font-display); letter-spacing: -0.05em; color: #2a2638; font-variant-numeric: tabular-nums; }
  .badge { display: inline-block; margin-bottom: 6px; font: 700 9px/1 var(--font-mono); letter-spacing: 0.22em; text-transform: uppercase; color: var(--accent-orange); }
  .title { font: 700 36px/1.05 var(--font-display); letter-spacing: -0.03em; color: #fff; margin: 6px 0 8px; }
  .title em { color: var(--accent-warm); font-style: normal; font-family: var(--font-italic); font-weight: 400; }
  .meta { font: 500 11px/1.3 var(--font-mono); color: var(--text-muted); margin: 0 0 16px; }
  .desc { font: 400 15px/1.55 var(--font-display); color: var(--text-sec); margin: 0 0 22px; max-width: 540px; }
  .desc strong { color: var(--text-pri); font-weight: 500; }
  .stack { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 18px; }
  .chip { font: 600 10px/1 var(--font-mono); letter-spacing: 0.06em; padding: 5px 9px; background: rgba(255, 210, 154, 0.08); color: var(--text-sec); border-radius: 2px; }
  .more {
    display: inline-flex; align-items: center; gap: 6px;
    font: 600 12px/1 var(--font-display); color: var(--accent-warm);
    text-decoration: none;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    border-bottom: 1px dotted rgba(255, 210, 154, 0.3);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }
  .more:hover { color: #fff; border-color: var(--accent-warm); }
  .more:focus-visible { outline: 2px solid var(--accent-warm); outline-offset: 4px; border-radius: 2px; }
  .more[aria-disabled="true"] { opacity: 0.7; cursor: default; border-bottom-color: transparent; }

  @media (max-width: 900px) {
    .feat-band, .feat-band.reverse {
      grid-template-columns: 1fr;
    }
    .feat-band.reverse .illu-col,
    .feat-band.reverse .text-col { order: unset; }
    .illu-col {
      width: 100%;
      justify-content: center;
    }
    .text-col {
      text-align: center;
    }
    .desc { margin-left: auto; margin-right: auto; }
    .stack { justify-content: center; }
  }
  @media (max-width: 600px) {
    .num { font-size: 44px; }
    .title { font-size: 28px; }
  }
</style>
