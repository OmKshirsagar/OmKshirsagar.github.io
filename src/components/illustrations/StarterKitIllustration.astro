---
// Featured 02 — FastAPI Starter Kit illustration
// Central "kit" core with 4 modular puzzle pieces (AUTH · DB · MCP · OBS)
// snapping into each side, and 3 service cards floating above ("VOICE AI",
// "AGENT", "DATA API") showing what teams build ON TOP of the kit.
// A 12+ adoption counter sits in the upper-right corner.
---
<div class="illu">
  <svg viewBox="0 0 300 300" fill="none">
    <defs>
      <linearGradient id="kit-core" x1="0" y1="0" x2="1" y2="1">
        <stop offset="0%" stop-color="#ffe6b8"/>
        <stop offset="100%" stop-color="#ff9460"/>
      </linearGradient>
      <radialGradient id="kit-halo" cx="50%" cy="55%" r="55%">
        <stop offset="0%" stop-color="#ffaa78" stop-opacity="0.18"/>
        <stop offset="100%" stop-color="#ffaa78" stop-opacity="0"/>
      </radialGradient>
    </defs>

    <!-- ambient halo -->
    <ellipse cx="150" cy="155" rx="125" ry="105" fill="url(#kit-halo)"/>

    <!-- =================================================== -->
    <!--  SERVICES BUILT ON TOP (3 small cards at the top)   -->
    <!-- =================================================== -->
    <g>
      <!-- service 1: VOICE AI (left) -->
      <g transform="translate(20, 22)">
        <rect width="72" height="34" rx="3" fill="#14141c" stroke="#ffaa78" stroke-width="1.2"/>
        <rect x="6" y="6" width="6" height="6" fill="#ffaa78"/>
        <rect x="14" y="6" width="6" height="6" fill="#ffaa78" opacity="0.55"/>
        <rect x="22" y="6" width="6" height="6" fill="#ffaa78" opacity="0.3"/>
        <text font-family="JetBrains Mono" font-size="10" font-weight="700" letter-spacing="1.5" fill="#ffaa78" x="36" y="25" text-anchor="middle">VOICE AI</text>
      </g>

      <!-- service 2: AGENT (center) -->
      <g transform="translate(114, 16)">
        <rect width="72" height="34" rx="3" fill="#14141c" stroke="#8a6da0" stroke-width="1.2"/>
        <rect x="6" y="6" width="6" height="6" fill="#8a6da0"/>
        <rect x="14" y="6" width="6" height="6" fill="#8a6da0" opacity="0.55"/>
        <rect x="22" y="6" width="6" height="6" fill="#8a6da0" opacity="0.3"/>
        <text font-family="JetBrains Mono" font-size="10" font-weight="700" letter-spacing="1.5" fill="#8a6da0" x="36" y="25" text-anchor="middle">AGENT</text>
      </g>

      <!-- service 3: DATA API (right) -->
      <g transform="translate(208, 22)">
        <rect width="72" height="34" rx="3" fill="#14141c" stroke="#5af3d0" stroke-width="1.2"/>
        <rect x="6" y="6" width="6" height="6" fill="#5af3d0"/>
        <rect x="14" y="6" width="6" height="6" fill="#5af3d0" opacity="0.55"/>
        <rect x="22" y="6" width="6" height="6" fill="#5af3d0" opacity="0.3"/>
        <text font-family="JetBrains Mono" font-size="10" font-weight="700" letter-spacing="1.5" fill="#5af3d0" x="36" y="25" text-anchor="middle">DATA API</text>
      </g>
    </g>

    <!-- =================================================== -->
    <!--  CONNECTOR LINES (services → kit core)              -->
    <!-- =================================================== -->
    <g stroke="#ffd29a" stroke-width="1" stroke-dasharray="3 2" fill="none" opacity="0.45">
      <path d="M 56 56 L 124 100"/>
      <path d="M 150 50 L 150 100"/>
      <path d="M 244 56 L 176 100"/>
    </g>

    <!-- =================================================== -->
    <!--  PUZZLE FOUNDATION                                   -->
    <!--  Center = kit core. 4 modular pieces snap in via    -->
    <!--  semicircular tabs that fit into the core.          -->
    <!-- =================================================== -->

    <!-- CENTER piece drawn FIRST so the 4 surrounding tabs visually overlap it -->
    <rect x="120" y="120" width="60" height="60" rx="3" fill="url(#kit-core)" stroke="#1a0f08" stroke-width="1.3"/>
    <text x="150" y="148" font-family="Inter" font-size="11" font-weight="800" letter-spacing="-0.5" fill="#1a0f08" text-anchor="middle">FastAPI</text>
    <text x="150" y="160" font-family="JetBrains Mono" font-size="7" font-weight="700" letter-spacing="2" fill="#1a0f08" text-anchor="middle">STARTER</text>
    <text x="150" y="170" font-family="JetBrains Mono" font-size="7" font-weight="700" letter-spacing="2" fill="#1a0f08" text-anchor="middle">KIT</text>

    <!-- TOP piece: AUTH (tab bumps DOWN into kit core's top edge) -->
    <path d="M 120 90 L 180 90 L 180 120 L 158 120 A 8 8 0 0 1 142 120 L 120 120 Z"
          fill="#ffaa78" stroke="#1a0f08" stroke-width="1.2"/>
    <text x="150" y="108" font-family="JetBrains Mono" font-size="10" font-weight="800" letter-spacing="1.8" fill="#1a0f08" text-anchor="middle">AUTH</text>

    <!-- RIGHT piece: DB (tab bumps LEFT into kit core's right edge) -->
    <path d="M 180 122 L 212 122 L 212 178 L 180 178 L 180 158 A 8 8 0 0 1 180 142 Z"
          fill="#8a6da0" stroke="#1a0f08" stroke-width="1.2"/>
    <text x="196" y="153" font-family="JetBrains Mono" font-size="10" font-weight="800" letter-spacing="1.8" fill="#fff5e8" text-anchor="middle">DB</text>

    <!-- BOTTOM piece: MCP (tab bumps UP into kit core's bottom edge).
         sweep=1 here (not 0) — going RIGHT from (142,180) to (158,180), the
         increasing-angle SVG direction passes through angle 270° (= UP in
         y-down coords), which is the bulge into the centre we want. -->
    <path d="M 120 180 L 142 180 A 8 8 0 0 1 158 180 L 180 180 L 180 210 L 120 210 Z"
          fill="#5af3d0" stroke="#1a0f08" stroke-width="1.2"/>
    <text x="150" y="199" font-family="JetBrains Mono" font-size="10" font-weight="800" letter-spacing="1.8" fill="#1a0f08" text-anchor="middle">MCP</text>

    <!-- LEFT piece: OBS (tab bumps RIGHT into kit core's left edge) -->
    <path d="M 88 122 L 120 122 L 120 142 A 8 8 0 0 1 120 158 L 120 178 L 88 178 Z"
          fill="#ffd29a" stroke="#1a0f08" stroke-width="1.2"/>
    <text x="104" y="153" font-family="JetBrains Mono" font-size="10" font-weight="800" letter-spacing="1.8" fill="#1a0f08" text-anchor="middle">OBS</text>

    <!-- Small connector dots in the seams (decorative — emphasize puzzle joins) -->
    <g fill="#1a0f08" opacity="0.4">
      <circle cx="150" cy="90" r="0.8"/>
      <circle cx="212" cy="150" r="0.8"/>
      <circle cx="150" cy="210" r="0.8"/>
      <circle cx="88" cy="150" r="0.8"/>
    </g>

    <!-- =================================================== -->
    <!--  Caption beneath puzzle (folds the 12+ adoption     -->
    <!--  count into the line so the badge no longer         -->
    <!--  collides with the DATA API service card).          -->
    <!-- =================================================== -->
    <text x="150" y="240" font-family="JetBrains Mono" font-size="9" font-weight="700" letter-spacing="3" fill="#a09387" text-anchor="middle">
      ONE FOUNDATION · <tspan fill="#ffd29a" font-weight="800">12+</tspan> SERVICES BUILT
    </text>
  </svg>
</div>

<style>
  .illu {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 1 / 1;
    background: radial-gradient(ellipse at center, rgba(255, 210, 154, 0.06) 0%, transparent 70%);
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 0 1 420px;
    margin: 0 auto;
  }
  .illu svg {
    width: 100%;
    max-width: 400px;
    height: auto;
    display: block;
  }
</style>
