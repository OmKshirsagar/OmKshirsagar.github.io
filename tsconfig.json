{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["vitest/globals", "@types/react", "@types/react-dom", "node"]
  },
  "include": ["src", "tests", "astro.config.mjs"],
  "exclude": ["node_modules", "dist", ".astro"]
}
