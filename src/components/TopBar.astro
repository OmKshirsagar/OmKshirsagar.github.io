---
// Top bar — minimal logo + "available" status pill
---
<header class="topbar">
  <div class="logo">om<span>.kshirsagar</span></div>
  <div class="status">Open to new opportunities</div>
</header>

<style>
  .topbar {
    padding: 18px clamp(20px, 4vw, 60px);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    position: relative;
    z-index: 2;
  }
  .logo {
    font: 800 22px/1 var(--font-display);
    letter-spacing: -0.02em;
    color: var(--accent-warm);
    flex-shrink: 0;
  }
  .logo span {
    color: var(--text-dim);
    font-weight: 500;
  }
  .status {
    font: 500 10px/1 var(--font-mono);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--status-active);
    text-align: right;
  }
  .status::before {
    content: '● ';
  }

  /* Mobile: shrink status text, then hide it on tiny screens */
  @media (max-width: 600px) {
    .status {
      font-size: 9px;
      letter-spacing: 0.1em;
      max-width: 50%;
      line-height: 1.2;
    }
  }
  @media (max-width: 420px) {
    .status {
      font-size: 0;
    }
    .status::before {
      content: '●';
      font-size: 12px;
    }
  }
</style>
