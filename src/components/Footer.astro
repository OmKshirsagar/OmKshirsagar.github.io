---
import { footerData } from '@/data/select';
const data = footerData();
const headingParts = data.heading.split('in touch');
const subhead = data.subhead.replace(/,?\s*or scan the QR\.?/i, '.');
---
<footer class="footer" id="contact">
  <div class="footer-inner">
  <h2 class="ttl">
    {headingParts.map((part, i) => (
      i === 0 ? <Fragment>{part}</Fragment> : <Fragment><em>in touch</em>{part}</Fragment>
    ))}
  </h2>
  <p class="sub">{subhead}</p>

  <div class="links">
    {data.links.map((l) => (
      <a class="flink" href={l.href}>
        <b>{l.chipLabel}</b> {l.label}
      </a>
    ))}
  </div>

  <div class="meta-bar">
    <div class="meta-left">
      <span class="copy">© {new Date().getFullYear()} Om Kshirsagar</span>
      <span class="sep" aria-hidden="true">·</span>
      <span class="role">Software Engineer I, Deloitte</span>
    </div>
    <div class="meta-right">
      <a class="meta-link" href="https://github.com/OmKshirsagar/OmKshirsagar.github.io" target="_blank" rel="noopener">
        View source <span class="arr">↗</span>
      </a>
      <span class="sep" aria-hidden="true">·</span>
      <span class="built">
        Built with <b>Astro</b> · <b>React</b> · <b>WebGPU</b> · hosted on <b>GitHub Pages</b>
      </span>
    </div>
  </div>
  </div>
</footer>

<style>
  .footer {
    background: #060609;
  }
  .footer-inner {
    max-width: var(--content-max, 1200px);
    margin: 0 auto;
    padding: 60px clamp(20px, 4vw, 60px) 80px;
  }
  .ttl {
    font: 700 26px/1 var(--font-display);
    color: #fff;
    margin: 0 0 6px;
  }
  .ttl em {
    color: var(--accent-warm);
    font-style: normal;
    font-family: var(--font-italic);
    font-weight: 400;
  }
  .sub {
    font: 400 13px/1.4 var(--font-display);
    color: var(--text-muted);
    margin: 0 0 22px;
  }
  /* 4 link chips, equal width, fill full row */
  .links {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }
  .flink {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 18px;
    background: var(--bg-surface);
    border: 1px solid #2a2638;
    border-radius: 6px;
    color: var(--text-pri);
    font: 500 13px/1 var(--font-display);
    text-decoration: none;
    transition: border-color 0.2s, background 0.2s, transform 0.2s;
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .flink:hover {
    border-color: rgba(255, 210, 154, 0.5);
    background: rgba(255, 210, 154, 0.04);
    transform: translateY(-1px);
  }
  .flink b {
    color: var(--accent-warm);
    font-weight: 700;
    text-transform: lowercase;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  @media (max-width: 900px) {
    .links { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .links { grid-template-columns: 1fr; }
  }

  .meta-bar {
    margin-top: 56px;
    padding-top: 22px;
    border-top: 1px solid rgba(255, 210, 154, 0.08);
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px 24px;
    font: 500 11px/1.4 var(--font-mono);
    color: var(--text-muted);
  }
  .meta-left, .meta-right {
    display: inline-flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;
  }
  .meta-bar .sep { opacity: 0.4; }
  .meta-bar .copy { color: var(--text-sec); font-weight: 600; letter-spacing: 0.02em; }
  .meta-bar .role { color: var(--text-muted); }
  .meta-link {
    color: var(--accent-warm);
    text-decoration: none;
    border-bottom: 1px dotted rgba(255, 210, 154, 0.3);
    padding-bottom: 1px;
    transition: border-color 0.2s, color 0.2s;
  }
  .meta-link:hover { color: #fff; border-color: var(--accent-warm); }
  .meta-link .arr { font-size: 9px; margin-left: 1px; }
  .built b { color: var(--text-sec); font-weight: 600; }

  @media (max-width: 720px) {
    .meta-bar {
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
      font-size: 10px;
    }
    .meta-left, .meta-right { gap: 6px; }
  }
</style>
