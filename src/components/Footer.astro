---
import { footerData } from '@/data/select';
const data = footerData();
const headingParts = data.heading.split('in touch');
---
<footer class="footer" id="contact">
  <h2 class="ttl">
    {headingParts.map((part, i) => (
      i === 0 ? <Fragment>{part}</Fragment> : <Fragment><em>in touch</em>{part}</Fragment>
    ))}
  </h2>
  <p class="sub">{data.subhead}</p>

  <div class="links">
    {data.links.map((l) => (
      <a class="flink" href={l.href}>
        <b>{l.chipLabel}</b> {l.label}
      </a>
    ))}
  </div>

  <div class="qr">
    <!-- Mock QR pattern (decorative; not scannable) -->
    <svg viewBox="0 0 60 60" fill="none" aria-hidden="true">
      <rect width="60" height="60" fill="#14141c" />
      <g fill="#ffd29a">
        <!-- corner finders -->
        <rect x="2" y="2" width="14" height="14" />
        <rect x="4" y="4" width="10" height="10" fill="#14141c" />
        <rect x="6" y="6" width="6" height="6" />

        <rect x="44" y="2" width="14" height="14" />
        <rect x="46" y="4" width="10" height="10" fill="#14141c" />
        <rect x="48" y="6" width="6" height="6" />

        <rect x="2" y="44" width="14" height="14" />
        <rect x="4" y="46" width="10" height="10" fill="#14141c" />
        <rect x="6" y="48" width="6" height="6" />

        <!-- data dots (decorative) -->
        <rect x="20" y="4" width="2" height="2" />
        <rect x="24" y="4" width="2" height="2" />
        <rect x="30" y="4" width="2" height="2" />
        <rect x="36" y="4" width="2" height="2" />
        <rect x="20" y="8" width="2" height="2" />
        <rect x="28" y="8" width="2" height="2" />
        <rect x="34" y="8" width="2" height="2" />
        <rect x="22" y="12" width="2" height="2" />
        <rect x="26" y="12" width="2" height="2" />
        <rect x="32" y="12" width="2" height="2" />
        <rect x="38" y="12" width="2" height="2" />
        <rect x="4" y="20" width="2" height="2" />
        <rect x="10" y="20" width="2" height="2" />
        <rect x="18" y="20" width="2" height="2" />
        <rect x="24" y="20" width="2" height="2" />
        <rect x="30" y="20" width="2" height="2" />
        <rect x="38" y="20" width="2" height="2" />
        <rect x="44" y="20" width="2" height="2" />
        <rect x="52" y="20" width="2" height="2" />
        <rect x="6" y="24" width="2" height="2" />
        <rect x="14" y="24" width="2" height="2" />
        <rect x="22" y="24" width="2" height="2" />
        <rect x="28" y="24" width="2" height="2" />
        <rect x="36" y="24" width="2" height="2" />
        <rect x="42" y="24" width="2" height="2" />
        <rect x="50" y="24" width="2" height="2" />
        <rect x="56" y="24" width="2" height="2" />
        <rect x="20" y="28" width="2" height="2" />
        <rect x="26" y="28" width="2" height="2" />
        <rect x="34" y="28" width="2" height="2" />
        <rect x="40" y="28" width="2" height="2" />
        <rect x="48" y="28" width="2" height="2" />
        <rect x="4" y="32" width="2" height="2" />
        <rect x="12" y="32" width="2" height="2" />
        <rect x="22" y="32" width="2" height="2" />
        <rect x="30" y="32" width="2" height="2" />
        <rect x="38" y="32" width="2" height="2" />
        <rect x="46" y="32" width="2" height="2" />
        <rect x="54" y="32" width="2" height="2" />
        <rect x="8" y="36" width="2" height="2" />
        <rect x="16" y="36" width="2" height="2" />
        <rect x="24" y="36" width="2" height="2" />
        <rect x="32" y="36" width="2" height="2" />
        <rect x="40" y="36" width="2" height="2" />
        <rect x="50" y="36" width="2" height="2" />
        <rect x="20" y="44" width="2" height="2" />
        <rect x="26" y="44" width="2" height="2" />
        <rect x="34" y="44" width="2" height="2" />
        <rect x="40" y="44" width="2" height="2" />
        <rect x="22" y="48" width="2" height="2" />
        <rect x="28" y="48" width="2" height="2" />
        <rect x="36" y="48" width="2" height="2" />
        <rect x="44" y="48" width="2" height="2" />
        <rect x="20" y="52" width="2" height="2" />
        <rect x="30" y="52" width="2" height="2" />
        <rect x="38" y="52" width="2" height="2" />
        <rect x="24" y="56" width="2" height="2" />
        <rect x="32" y="56" width="2" height="2" />
        <rect x="40" y="56" width="2" height="2" />
      </g>
    </svg>
    <div class="qr-text">
      <b>QR-share ready.</b> {data.qrTagline}
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: 60px 40px 80px;
    background: #060609;
  }
  .ttl {
    font: 700 26px/1 var(--font-display);
    color: #fff;
    margin: 0 0 6px;
  }
  .ttl em {
    color: var(--accent-warm);
    font-style: normal;
    font-family: var(--font-italic);
    font-weight: 400;
  }
  .sub {
    font: 400 13px/1.4 var(--font-display);
    color: var(--text-muted);
    margin: 0 0 22px;
  }
  .links { display: flex; gap: 10px; flex-wrap: wrap; }
  .flink {
    padding: 12px 18px;
    background: var(--bg-surface);
    border: 1px solid #2a2638;
    border-radius: 4px;
    color: var(--text-pri);
    font: 600 12px/1 var(--font-display);
    text-decoration: none;
    transition: border-color 0.2s;
  }
  .flink:hover { border-color: rgba(255, 210, 154, 0.4); }
  .flink b { color: var(--accent-warm); margin-right: 8px; }

  .qr {
    margin-top: 20px;
    padding: 18px 22px;
    background: var(--bg-surface);
    border: 1px dashed rgba(255, 210, 154, 0.3);
    border-radius: 6px;
    display: inline-flex;
    align-items: center;
    gap: 16px;
    font: 500 12px/1.4 var(--font-display);
    color: var(--text-sec);
  }
  .qr svg { width: 60px; height: 60px; flex: 0 0 60px; }
  .qr-text b {
    color: var(--text-pri);
    font-weight: 600;
  }
</style>
